<?xml version="1.0" encoding="UTF-8" ?>
<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service
            id="chamilo.libraries.calendar.service.calendar_source_service"
            class="Chamilo\Libraries\Calendar\Service\CalendarSourceService">
        </service>

        <service
            id="chamilo.libraries.calendar.service.legend_renderer"
            class="Chamilo\Libraries\Calendar\Service\LegendRenderer">
            <argument
                type="service"
                id="chamilo.libraries.calendar.service.calendar_source_service" />
            <argument
                type="service"
                id="symfony.component.translation.translator" />
            <argument
                type="service"
                id="chamilo.libraries.file.path_builder" />
            <argument
                type="service"
                id="chamilo.libraries.format.utilities.resource_manager" />
        </service>
    </services>
</container>