<?xml version="1.0" encoding="UTF-8" ?>
<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service
            id="chamilo.libraries.calendar.format.service.html_table_renderer_factory"
            class="Chamilo\Libraries\Calendar\Format\Service\HtmlTableRendererFactory">
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_sources" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_configuration" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.format.service.calendar_builder_factory" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.event.service.html_table_renderer_factory" />
        </service>

        <service
            id="chamilo.libraries.calendar.format.service.calendar_builder_factory"
            class="Chamilo\Libraries\Calendar\Format\Service\CalendarBuilderFactory">
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_configuration" />
            <argument
                type="service"
                id="symfony.component.translation.translator" />
        </service>

        <service
            id="chamilo.libraries.calendar.event.service.html_table_renderer_factory"
            class="Chamilo\Libraries\Calendar\Event\Service\HtmlTableRendererFactory">
            <argument
                type="service"
                id="chamilo.libraries.architecture.classname_utilities" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_sources" />
        </service>


        <service
            id="chamilo.libraries.calendar.calendar_sources"
            class="Chamilo\Libraries\Calendar\CalendarSources">
        </service>

        <service
            id="chamilo.libraries.calendar.service.legend_renderer"
            class="Chamilo\Libraries\Calendar\Service\LegendRenderer">
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_sources" />
            <argument
                type="service"
                id="symfony.component.translation.translator" />
            <argument
                type="service"
                id="chamilo.libraries.file.path_builder" />
            <argument
                type="service"
                id="chamilo.libraries.format.utilities.resource_manager" />
        </service>

        <service
            id="chamilo.libraries.calendar.service.calendar_configuration_factory"
            class="Chamilo\Libraries\Calendar\Service\CalendarConfigurationFactory">
            <argument
                type="service"
                id="chamilo.libraries.platform.configuration.local_setting" />
        </service>

        <service
            id="chamilo.libraries.calendar.calendar_configuration"
            class="Chamilo\Libraries\Calendar\CalendarConfiguration"
            factory-service="chamilo.libraries.calendar.service.calendar_configuration_factory"
            factory-method="getCalendarConfiguration">
        </service>

    </services>
</container>