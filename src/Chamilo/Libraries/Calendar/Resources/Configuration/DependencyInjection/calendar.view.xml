<?xml version="1.0" encoding="UTF-8" ?>
<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service
            id="chamilo.libraries.calendar.view.service.view_html_table_renderer_factory"
            class="Chamilo\Libraries\Calendar\View\Service\ViewHtmlTableRendererFactory">
            <argument
                type="service"
                id="twig.environment" />
            <argument
                type="service"
                id="chamilo.libraries.utilities.datetime_utilities" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.format.service.format_html_table_renderer_factory" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.service.legend_renderer" />

        </service>
    </services>
</container>