<?xml version="1.0" encoding="UTF-8" ?>
<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service
            id="chamilo.libraries.calendar.format.service.format_html_table_renderer_factory"
            class="Chamilo\Libraries\Calendar\Format\Service\FormatHtmlTableRendererFactory">
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_sources" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_configuration" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.format.service.calendar_builder_factory" />
            <argument
                type="service"
                id="chamilo.libraries.calendar.event.service.event_html_table_renderer_factory" />
        </service>

        <service
            id="chamilo.libraries.calendar.format.service.calendar_builder_factory"
            class="Chamilo\Libraries\Calendar\Format\Service\CalendarBuilderFactory">
            <argument
                type="service"
                id="chamilo.libraries.calendar.calendar_configuration" />
            <argument
                type="service"
                id="symfony.component.translation.translator" />
        </service>
    </services>
</container>